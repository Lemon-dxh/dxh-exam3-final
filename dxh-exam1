#!/bin/bash
# ============================================================
# Script Name: dxh-exam1
# Author:     DengXiaoHui (DengXiaoHui)
# Student ID: 23310137
# Description: Accepts a positive integer n, creates n
#              lemon-x.MP3 files in dxhgit directory,
#              with trap cleanup mechanism
# ============================================================

# --- Global Variables ---
FRUIT="lemon"
TARGET_DIR="$HOME/dxhgit"
CREATED_FILES=""

# --- Trap Cleanup Function ---
cleanup() {
    if [ -n "$CREATED_FILES" ]; then
        echo "[cleanup] Cleaning up files created by this run..."
        for f in $CREATED_FILES; do
            if [ -f "$TARGET_DIR/$f" ]; then
                rm -f "$TARGET_DIR/$f"
                echo "[cleanup] Deleted: $TARGET_DIR/$f"
            fi
        done
    fi
    echo "[cleanup] Cleanup completed."
}
trap cleanup EXIT INT TERM

# --- Parameter Validation ---
if [ $# -ne 1 ]; then
    echo "Error: Script requires exactly one positive integer parameter."
    echo "Usage: $0 <positive_integer>"
    read -r -n 1
    exit 1
fi

if ! [[ "$1" =~ ^[1-9][0-9]*$ ]]; then
    echo "Error: '$1' is not a positive integer."
    echo "Usage: $0 <positive_integer>"
    read -r -n 1
    exit 1
fi

N=$1

# --- Main Logic ---
echo "DengXiaoHui will create $N files"

if [ ! -d "$TARGET_DIR" ]; then
    echo "Error: Target directory $TARGET_DIR does not exist."
    exit 1
fi

cd "$TARGET_DIR" || exit 1

for (( i=1; i<=N; i++ )); do
    FILENAME="${FRUIT}-${i}.MP3"
    if [ -f "$FILENAME" ]; then
        echo "[SKIP] $FILENAME already exists."
    else
        touch "$FILENAME"
        echo "[CREATE] $FILENAME"
        CREATED_FILES="$CREATED_FILES $FILENAME"
    fi
done

echo ""
echo "DengXiaoHui fin"
echo "--- Newly created files ---"
if [ -z "$CREATED_FILES" ]; then
    echo "(No new files created, all already exist)"
else
    for f in $CREATED_FILES; do
        echo "  $TARGET_DIR/$f"
    done
fi
echo "--- Current Time T2 ---"
date "+%Y-%m-%d %H:%M:%S"

read -r -n 1
exit 0
