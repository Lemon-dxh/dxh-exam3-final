#!/bin/bash
# ============================================================
# Script Name: dxh-exam2
# Author:     DengXiaoHui (DengXiaoHui)
# Student ID: 23310137
# Description: Student ID/Major validation + simulated useradd
# ============================================================

clear

echo "========================================"
echo "  Linux Final Exam - dxh-exam2"
echo "  Author: DengXiaoHui (DengXiaoHui)  ID: 23310137"
echo "========================================"
echo ""

# --- Student ID Validation ---
STUDENT_ID=""
while true; do
    read -r -p "Enter student ID (enter q to quit): " INPUT_ID

    if [ "$INPUT_ID" = "q" ] || [ "$INPUT_ID" = "Q" ]; then
        echo "User chose to exit."
        exit 0
    fi

    if [[ "$INPUT_ID" =~ ^[A-Z]?[0-9]{8}$ ]]; then
        STUDENT_ID="$INPUT_ID"
        echo "Student ID $STUDENT_ID validation passed."
        break
    else
        echo "Error: Invalid student ID format!"
        echo "  Valid examples: Z23310401, 23310211"
    fi
done

echo ""

# --- Major Validation ---
MAJOR=""
while true; do
    read -r -p "Enter major (English, enter q to quit): " INPUT_MAJOR

    if [ "$INPUT_MAJOR" = "q" ] || [ "$INPUT_MAJOR" = "Q" ]; then
        echo "User chose to exit."
        exit 0
    fi

    if [[ "$INPUT_MAJOR" =~ ^[a-zA-Z]+$ ]]; then
        MAJOR="$INPUT_MAJOR"
        echo "Major $MAJOR validation passed."
        break
    else
        echo "Error: Major must contain only English letters!"
    fi
done

echo ""

# --- Simulated useradd ---
echo "========================================"
echo "  Simulated User Creation"
echo "========================================"
echo ""

if id "$STUDENT_ID" &>/dev/null; then
    echo "User $STUDENT_ID already exists, no action needed."
else
    echo "User $STUDENT_ID does not exist. Would run:"
    echo ""
    echo "  useradd -g $MAJOR $STUDENT_ID"
    echo ""
    echo "(Note: Command is only displayed, not actually executed.)"
fi

echo ""
echo "========================================"
echo "  Current Time T3"
echo "========================================"
date "+%Y-%m-%d %H:%M:%S"

read -r -n 1
exit 0
EOF

chmod +x dxh-exam2
